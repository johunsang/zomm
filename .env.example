# ─────────────────────────────────────────────────────────────
# zomm 환경변수 예시 — 복사해서 .env 로 저장하세요.
#
# 기본(BYO) 모드에서는 키를 .env 가 아니라 브라우저 설정 화면에 입력합니다.
# 아래 CF_* 키는 "중앙 호스팅 / Workers 배포" 모드에서만 필요합니다
# (= 학생이 키 없이 링크만으로 입장하게 하려는 경우).
# ─────────────────────────────────────────────────────────────

# 로컬 프록시 포트
PORT=8787

# 강의 1개당 입장 가능한 최대 인원 (0 = 무제한). 예: 300 으로 두면 300명 제한.
MAX_PARTICIPANTS=0

# Cloudflare 대시보드에 만들어 둔 preset 이름과 일치시킬 것
# 강의(웨비나) 역할: 강사=발표, 수강생=채팅만(카메라·마이크 없음). 이름은 대시보드 Presets와 일치시킬 것.
RTK_HOST_PRESET=webinar_presenter
RTK_PARTICIPANT_PRESET=webinar_viewer

# ── 아래는 선택(중앙 호스팅 모드 전용) ──────────────────────────
# Cloudflare 대시보드 → Realtime → RealtimeKit 에서 발급
# CF_ACCOUNT_ID=
# CF_REALTIMEKIT_APP_ID=
# CF_API_TOKEN=
